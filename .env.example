# Fibratur - exemplo de variaveis de ambiente

# Servidor
PORT=5173
HOST=0.0.0.0

# Persistencia em producao. Use disco persistente.
DATA_DIR=/var/data/fibratur

# Login HTTP basico em producao.
APP_USER=admin
APP_PASSWORD=troque-essa-senha

# Supabase opcional. O app funciona com arquivos JSON locais.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

